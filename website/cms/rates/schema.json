{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bigbendburro.com/schemas/seasonal-rates.schema.json",
  "title": "Seasonal Rate Ruleset",
  "type": "object",
  "required": [
    "defaultRate",
    "seasons"
  ],
  "properties": {
    "defaultRate": {
      "type": "object",
      "required": [
        "nightly",
        "cleaningFee"
      ],
      "properties": {
        "nightly": {
          "type": "number",
          "minimum": 0
        },
        "cleaningFee": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "seasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "seasonId",
          "name",
          "startDate",
          "endDate",
          "rates"
        ],
        "properties": {
          "seasonId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "pattern": "^\\d{2}-\\d{2}$"
          },
          "endDate": {
            "type": "string",
            "pattern": "^\\d{2}-\\d{2}$"
          },
          "rates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "unitId",
                "nightly",
                "cleaningFee"
              ],
              "properties": {
                "unitId": {
                  "type": "string"
                },
                "nightly": {
                  "type": "number",
                  "minimum": 0
                },
                "weeklyDiscount": {
                  "type": "number",
                  "minimum": 0
                },
                "cleaningFee": {
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          },
          "blackoutDates": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            }
          }
        }
      }
    }
  }
}
