# Operator Authentication
# Set these in production to secure operator access

# Session secret - use a long random string
OPERATOR_SESSION_SECRET=your-secret-key-here-change-in-production

# Default operator credentials (fallback if individual not set)
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=change-this-password

# Individual operator passwords (optional - override defaults)
CHUCK_PASSWORD=change-this-password
SUSAN_PASSWORD=change-this-password

# Base URL for redirects
NEXT_PUBLIC_BASE_URL=http://localhost:3000
